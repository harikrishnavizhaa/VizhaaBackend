# Database
DATABASE_URL="postgresql://user:password@localhost:5432/vizhaa?schema=public"

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=30d

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour Firebase Private Key\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Razorpay
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Platform Settings
PLATFORM_COMMISSION_PERCENTAGE=12
ADVANCE_PAYMENT_PERCENTAGE=25
SUPPLIER_SEARCH_RADIUS_KM=20

# Frontend URLs (for CORS)
ORGANIZER_APP_URL=http://localhost:8081
SUPPLIER_APP_URL=http://localhost:8082
ADMIN_PANEL_URL=http://localhost:3001
